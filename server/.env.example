# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/payment_planner
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payment_planner
DB_USER=postgres
DB_PASSWORD=your-password

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Microsoft 365 SSO Configuration
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
REDIRECT_URI=http://localhost:5000/auth/callback

# Email Configuration
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@company.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=finance@company.com
EMAIL_FROM_NAME=Finance Team

# Email Recipients (comma-separated)
DEFAULT_EMAIL_RECIPIENTS=finance@company.com,admin@company.com

# Frontend URL
CLIENT_URL=http://localhost:5173

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Cron Schedule (Friday at 4:00 PM)
EMAIL_CRON_SCHEDULE=0 16 * * 5
